# Keep the build context small and the image clean.

# Dependencies — reinstalled inside the build stages.
node_modules
web/node_modules
server/**/node_modules

# Build output — regenerated in-image.
dist
web/dist
out
**/bin/
**/obj/

# The 80 MB derived SQLite store — rebuilt from the CR API at runtime.
meta.db
meta.db-wal
meta.db-shm

# Secrets — the API key is passed at run time, never copied in.
.env
.env.*

# VCS / logs / editor / test noise.
.git
.gitignore
*.log
coverage
*.lcov
.idea
.vscode
.DS_Store

# Test project isn't needed for the runtime image.
server/RoyaleDeckLab.Api.Tests
